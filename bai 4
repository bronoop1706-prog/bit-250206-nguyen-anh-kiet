
n = int(input("Nhập số phần tử n: "))

a = []
for i in range(n):
    x = int(input(f"Nhập phần tử thứ {i+1}: "))
    a.append(x)

print("Mảng ban đầu:", a)

step = 1

for i in range(n-1):
    for j in range(n-i-1):
        if a[j] > a[j+1]:
            a[j], a[j+1] = a[j+1], a[j]
            print(f"Bước {step}: {a}")
            step += 1
